# URL do backend (obrigatório para login).
# No simulador iOS ou dispositivo físico: localhost não funciona — use o IP da sua máquina, ex: http://192.168.1.10:3001
EXPO_PUBLIC_API_URL=http://localhost:3001

# Login social – Google (obrigatório para "Continuar com Gmail")
# Crie em https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, tipo "Web application")
# Adicione o redirect URI que o Expo mostrar no console ao rodar o app
EXPO_PUBLIC_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Login social – Facebook (obrigatório para "Continuar com Facebook")
# Crie um app em https://developers.facebook.com e adicione "Facebook Login"
EXPO_PUBLIC_FACEBOOK_APP_ID=seu-app-id
